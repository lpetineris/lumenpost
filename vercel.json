{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/bio/(.*)", "dest": "/api/bio" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
